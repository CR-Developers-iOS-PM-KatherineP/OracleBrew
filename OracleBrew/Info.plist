<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The rest of the Info.plist is still generated from build settings; this
	     file exists only for the launch screen. Xcode's
	     INFOPLIST_KEY_UILaunchScreen_* settings can't express the background
	     colour — Generation=YES writes an empty dict over it — and without a
	     colour the launch screen is white, which flashes before the dark
	     splash. -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
</dict>
</plist>
